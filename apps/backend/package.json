    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/serve-static": "^5.0.4",
    "@types/jsdom": "^27.0.0",
    "@types/multer": "^2.0.0",
    "@types/unidecode": "^1.1.0",
    "axios": "^1.13.5",
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "jsdom": "^28.1.0",
    "keyv": "^5.6.0",
    "multer": "^2.0.2",
    "puppeteer": "^24.37.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "unidecode": "^1.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
